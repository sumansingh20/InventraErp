# Inventra Enterprise ERP - Environment Configuration
# Copy this to .env and fill in your values

# ===== SERVER =====
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ===== DATABASE =====
MONGODB_URI=mongodb://localhost:27017/inventra_erp
MONGODB_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/inventra_erp?retryWrites=true&w=majority
DB_NAME=inventra_erp

# ===== REDIS =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ===== JWT =====
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-change-this-too
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ===== ENCRYPTION =====
ENCRYPTION_KEY=your-32-char-encryption-key-here!
BCRYPT_ROUNDS=12

# ===== EMAIL (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@inventra.io
EMAIL_FROM_NAME=Inventra ERP

# ===== SMS (Twilio / MSG91) =====
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your-msg91-key
MSG91_SENDER_ID=INVTRA
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE=+1234567890

# ===== PAYMENT GATEWAYS =====
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox

# ===== FILE STORAGE =====
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,xlsx,csv,docx

# ===== CLOUD STORAGE (AWS S3) =====
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=inventra-erp-files

# ===== FRONTEND URL =====
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ===== SUPER ADMIN =====
SUPER_ADMIN_EMAIL=superadmin@inventra.io
SUPER_ADMIN_PASSWORD=SuperAdmin@123!

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000

# ===== LOGS =====
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ===== GOOGLE OAUTH (Optional) =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== WHATSAPP (Twilio / WATI) =====
WATI_API_KEY=your-wati-api-key
WATI_BASE_URL=https://live-mt-server.wati.io

# ===== PUSH NOTIFICATIONS (Firebase) =====
FIREBASE_SERVER_KEY=your-firebase-server-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# ===== GST API =====
GST_API_URL=https://gst.gov.in/api
GST_API_KEY=your-gst-api-key

# ===== E-INVOICE (NIC / IRP) =====
IRP_API_URL=https://einvoice1.gst.gov.in
IRP_USERNAME=your-irp-username
IRP_PASSWORD=your-irp-password

# ===== SESSION =====
SESSION_SECRET=your-session-secret-change-this

# ===== COMPANY DEFAULT =====
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_DATE_FORMAT=DD/MM/YYYY
DEFAULT_TAX_TYPE=GST
